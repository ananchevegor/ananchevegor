<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/assets/title_logo.png" />
    <title>ananchev</title>
    <style>
        :root {
            --bg: #f4f4f1;
            --paper: #ffffff;
            --ink: #111111;
            --muted: #616161;
            --soft-line: rgba(17, 17, 17, 0.08);
            --line: rgba(17, 17, 17, 0.14);
            --shadow: 16px 16px 0 #111111;
            font-family: "SF Pro Display", "SF Pro Text", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            margin: 0;
            min-height: 100%;
            color: var(--ink);
            background:
                linear-gradient(to right, var(--soft-line) 1px, transparent 1px),
                linear-gradient(to bottom, var(--soft-line) 1px, transparent 1px),
                var(--bg);
            background-size: 32px 32px, 32px 32px, auto;
        }

        body {
            padding: 32px;
        }

        .page {
            width: min(1080px, 100%);
            margin: 0 auto;
            padding: 28px;
            border: 2px solid var(--ink);
            background: var(--paper);
            box-shadow: var(--shadow);
        }

        .topbar,
        .hero,
        .story-grid,
        .notes-grid {
            border-bottom: 1px solid var(--ink);
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            padding-bottom: 20px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .brand-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 46px;
            height: 46px;
            border: 1.5px solid var(--ink);
            font-size: 0.88rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
        }

        .brand-copy {
            display: grid;
            gap: 4px;
        }

        .brand-copy strong,
        .meta,
        .eyebrow,
        .tag,
        .section-label,
        .fact-label {
            text-transform: uppercase;
            letter-spacing: 0.16em;
        }

        .brand-copy strong {
            font-size: 0.88rem;
        }

        .brand-copy span,
        .meta,
        .lead,
        .photo-note,
        .section-card p,
        .fact-value,
        .closing-note {
            color: var(--muted);
        }

        .meta {
            font-size: 0.8rem;
            white-space: nowrap;
        }

        .hero {
            display: grid;
            grid-template-columns: minmax(0, 1.15fr) 320px;
            gap: 28px;
            padding: 36px 0 30px;
            align-items: start;
        }

        .eyebrow {
            margin: 0 0 18px;
            font-size: 0.76rem;
            font-weight: 700;
        }

        h1 {
            max-width: 10ch;
            margin: 0;
            font-size: clamp(3.1rem, 7vw, 6rem);
            line-height: 0.94;
            letter-spacing: -0.06em;
        }

        .lead {
            max-width: 42rem;
            margin: 22px 0 0;
            font-size: 1.08rem;
            line-height: 1.72;
        }

        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 26px;
        }

        .tag {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 42px;
            padding: 0 16px;
            border: 1.5px solid var(--ink);
            font-size: 0.74rem;
            font-weight: 700;
            text-decoration: none;
            color: var(--ink);
            transition: background-color 140ms ease, color 140ms ease;
        }

        .tag.link {
            gap: 10px;
        }

        .tag.link::after {
            font-size: 0.8rem;
            line-height: 1;
        }

        .tag:hover,
        .tag:focus-visible,
        .tag.active {
            background: var(--ink);
            color: var(--paper);
            outline: none;
        }

        .photo-card {
            padding: 14px;
            border: 1.5px solid var(--ink);
            background:
                linear-gradient(135deg, rgba(17, 17, 17, 0.05), transparent 58%),
                var(--paper);
        }

        .photo-card img {
            display: block;
            width: 100%;
            aspect-ratio: 4 / 5;
            object-fit: cover;
            border: 1px solid var(--ink);
        }

        .photo-note {
            margin: 12px 0 0;
            font-size: 0.92rem;
            line-height: 1.6;
        }

        .story-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
            padding: 28px 0;
        }

        .section-card {
            padding: 20px;
            border: 1px solid var(--ink);
            background: var(--paper);
        }

        .section-label {
            display: inline-block;
            margin-bottom: 16px;
            font-size: 0.74rem;
            font-weight: 700;
        }

        .section-card h2 {
            margin: 0 0 12px;
            max-width: 12ch;
            font-size: 1.65rem;
            line-height: 1.05;
            letter-spacing: -0.05em;
        }

        .section-card p {
            margin: 0;
            line-height: 1.68;
        }

        .notes-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.2fr) 280px;
            gap: 18px;
            padding: 28px 0;
        }

        .long-note,
        .fact-list {
            padding: 22px;
            border: 1px solid var(--ink);
            background: var(--paper);
        }

        .long-note h2,
        .fact-list h2 {
            margin: 0 0 16px;
            font-size: 1.2rem;
            text-transform: uppercase;
            letter-spacing: 0.14em;
        }

        .long-note p {
            max-width: 44rem;
            margin: 0 0 16px;
            color: var(--muted);
            line-height: 1.75;
        }

        .fact-list {
            display: grid;
            gap: 14px;
        }

        .fact {
            display: grid;
            gap: 6px;
            padding-bottom: 14px;
            border-bottom: 1px solid var(--line);
        }

        .fact:last-child {
            padding-bottom: 0;
            border-bottom: none;
        }

        .fact-label {
            font-size: 0.72rem;
            font-weight: 700;
        }

        .fact-value {
            line-height: 1.55;
        }

        .closing {
            padding-top: 22px;
        }

        .closing-note {
            max-width: 44rem;
            margin: 0;
            font-size: 1rem;
            line-height: 1.7;
        }

        .contact-links {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 18px;
        }

        .contact-link {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            min-height: 42px;
            padding: 0 16px;
            border: 1.5px solid var(--ink);
            color: var(--ink);
            text-decoration: none;
            font-size: 0.82rem;
            font-weight: 700;
            transition: background-color 140ms ease, color 140ms ease;
        }

        .contact-link svg {
            flex: 0 0 18px;
            width: 18px;
            height: 18px;
        }

        .contact-link:hover,
        .contact-link:focus-visible {
            background: var(--ink);
            color: var(--paper);
            outline: none;
        }

        @media (max-width: 980px) {
            body {
                padding: 20px;
            }

            .page {
                padding: 22px;
                box-shadow: 10px 10px 0 #111111;
            }

            .hero,
            .story-grid,
            .notes-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 720px) {
            .topbar {
                flex-direction: column;
                align-items: flex-start;
            }

            h1 {
                max-width: none;
                font-size: clamp(2.6rem, 16vw, 4.4rem);
            }
        }
    </style>
</head>
<body>
    <main class="page">
        <header class="topbar">
            <div class="brand">
                <div class="brand-mark">AB</div>
                <div class="brand-copy">
                    <strong>About Me</strong>
                    <span>A personal page about work, thinking, and direction</span>
                </div>
            </div>
            <div class="meta">Personal / Work / Notes</div>
        </header>

        <section class="hero">
            <div>
                <p class="eyebrow">About</p>
                <h1>I build, write, and keep learning in public.</h1>
                <p class="lead">
                    This page is a simple introduction to who I am, what I care about,
                    and why this blog exists. I like thoughtful systems, clean code,
                    calm interfaces, and the slow process of turning ideas into
                    something real.
                </p>

                <div class="tags">
                    <a class="tag link" href="/resnt">Research and Tests</a>
                    <a class="tag active" href="/about">About me</a>
                </div>
            </div>

            <aside class="photo-card">
                <img src="/assets/me.jpg" alt="Portrait" />
            </aside>
        </section>

        <section class="story-grid">
            <article class="section-card">
                <span class="section-label">01</span>
                <h2>What I do</h2>
                <p>
                    I work with code, ideas, and systems. I like building things that
                    feel structured, readable, and useful over time.
                </p>
            </article>

            <article class="section-card">
                <span class="section-label">02</span>
                <h2>What I write about</h2>
                <p>
                    This blog is a place for technical notes, experiments, personal
                    observations, and whatever feels worth keeping.
                </p>
            </article>

            <article class="section-card">
                <span class="section-label">03</span>
                <h2>Why this exists</h2>
                <p>
                    I wanted a space that feels personal and direct. No noise, no
                    overload, just a place to think and publish.
                </p>
            </article>
        </section>

        <section class="notes-grid">
            <article class="long-note">
                <h2>Short Story</h2>
                <p>
                    Since primary school, I have been interested in logic problems
                    and computer science. One of my earliest memories from third
                    grade is solving flowcharts and algorithm exercises, and I
                    genuinely loved it.
                </p>
                <p>
                    I wrote my first program in seventh grade, when I was 13 years
                    old. That was more than eleven years ago. It was a very simple
                    Pascal program that printed a value, but for me it was the
                    moment programming became something real.
                </p>
                <p>
                    At 15, I joined a programming academy where I spent three years
                    studying C#, Java, and PHP with MySQL. At that time there was no
                    AI to help with learning, so for a school student these tools
                    were difficult, but also very interesting. For my diploma
                    project, I built a small online bookstore. It was simple, with
                    no complex business logic or payments, but it already had
                    filters, order history, a cart, and email confirmations.
                </p>
                <p>
                    At university, I studied at the Institute of Applied Mathematics
                    and Mechanics. There I became familiar with numerical methods,
                    algorithms, matrices, mathematical analysis, linear algebra, and
                    geometry. That experience helped me better understand the nature
                    of learning and the principles behind applied problems.
                </p>
                <p>
                    Since 2021, I have worked on both commercial and non-commercial
                    projects. Since 2022, I have been actively developing mobile
                    applications, and from 2025 I moved toward enterprise solutions
                    and high-load systems. My goal is to make my applications as
                    fast and efficient as possible. Let us try to spend less of the
                    most valuable resource on the planet: time.
                </p>
            </article>

        </section>

        <section class="closing">
            <div class="contact-links" aria-label="Social links">
                <a class="contact-link" href="https://github.com/ananchevegor" target="_blank" rel="noreferrer">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 2.4a9.6 9.6 0 0 0-3 18.72c.48.09.66-.21.66-.48v-1.68c-2.7.6-3.27-1.14-3.27-1.14-.45-1.11-1.08-1.41-1.08-1.41-.9-.6.06-.57.06-.57 1.02.06 1.56 1.05 1.56 1.05.87 1.5 2.31 1.05 2.88.81.09-.66.36-1.05.63-1.29-2.16-.24-4.44-1.08-4.44-4.8 0-1.05.39-1.92 1.02-2.58-.09-.24-.45-1.23.12-2.55 0 0 .84-.27 2.73 1.02a9.45 9.45 0 0 1 4.98 0c1.89-1.29 2.73-1.02 2.73-1.02.57 1.32.21 2.31.12 2.55.66.66 1.02 1.53 1.02 2.58 0 3.72-2.28 4.56-4.47 4.8.36.3.66.87.66 1.77v2.61c0 .27.18.57.66.48A9.6 9.6 0 0 0 12 2.4Z" fill="currentColor"/>
                    </svg>
                    <span>GitHub</span>
                </a>

                <a class="contact-link" href="https://t.me/rea1eeea" target="_blank" rel="noreferrer">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M21.15 4.53 18.27 18.1c-.21.96-.78 1.2-1.59.75l-4.41-3.24-2.13 2.07c-.24.24-.42.42-.87.42l.3-4.53 8.28-7.5c.36-.33-.09-.51-.57-.18l-10.23 6.45-4.41-1.38c-.96-.3-.99-.96.21-1.41L19.38 3.2c.78-.3 1.47.18 1.77 1.32Z" fill="currentColor"/>
                    </svg>
                    <span>Telegram</span>
                </a>

                <a class="contact-link" href="mailto:egorka225522@gmail.com">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M3 6.75h18v10.5H3Z" fill="none" stroke="currentColor" stroke-width="1.8"/>
                        <path d="m4.5 8.25 7.5 6 7.5-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Email</span>
                </a>
            </div>
        </section>
    </main>
</body>
</html>
