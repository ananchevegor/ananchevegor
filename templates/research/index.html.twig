<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/assets/title_logo.png" />
    <title>ananchev</title>
    <style>
        :root {
            --bg: #f5f5f2;
            --paper: #ffffff;
            --ink: #111111;
            --muted: #626262;
            --line: rgba(17, 17, 17, 0.14);
            font-family: "SF Pro Display", "SF Pro Text", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            margin: 0;
            min-height: 100%;
            color: var(--ink);
            background:
                linear-gradient(to right, rgba(17, 17, 17, 0.04) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(17, 17, 17, 0.04) 1px, transparent 1px),
                var(--bg);
            background-size: 32px 32px, 32px 32px, auto;
        }

        body {
            padding: 32px;
        }

        .page {
            width: min(900px, 100%);
            margin: 0 auto;
            padding: 28px;
            border: 1.5px solid var(--ink);
            background: var(--paper);
        }

        .topbar,
        .archive-head,
        .article {
            border-bottom: 1px solid var(--ink);
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            padding-bottom: 20px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .brand-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            border: 1.5px solid var(--ink);
            font-size: 0.86rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
        }

        .brand-copy {
            display: grid;
            gap: 4px;
        }

        .brand-copy strong,
        .meta,
        .eyebrow,
        .tag,
        .archive-label,
        .article-index,
        .article-time {
            text-transform: uppercase;
            letter-spacing: 0.16em;
        }

        .brand-copy strong {
            font-size: 0.88rem;
        }

        .brand-copy span,
        .meta,
        .lead,
        .archive-head p,
        .article p,
        .article-time,
        .note {
            color: var(--muted);
        }

        .meta {
            font-size: 0.8rem;
            white-space: nowrap;
        }

        .intro {
            padding: 36px 0 30px;
        }

        .eyebrow {
            margin: 0 0 18px;
            font-size: 0.76rem;
            font-weight: 700;
        }

        h1 {
            max-width: 11ch;
            margin: 0;
            font-size: clamp(3rem, 7vw, 5.8rem);
            line-height: 0.94;
            letter-spacing: -0.06em;
        }

        .lead {
            max-width: 40rem;
            margin: 24px 0 0;
            font-size: 1.04rem;
            line-height: 1.7;
        }

        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 26px;
        }

        .tag {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 40px;
            padding: 0 16px;
            border: 1px solid var(--ink);
            font-size: 0.74rem;
            font-weight: 700;
            text-decoration: none;
            color: var(--ink);
            transition: background-color 140ms ease, color 140ms ease;
        }

        .tag.link {
            gap: 10px;
        }

        .tag.link::after {
            font-size: 0.78rem;
            line-height: 1;
        }

        .tag:hover,
        .tag:focus-visible,
        .tag.active {
            background: var(--ink);
            color: var(--paper);
            outline: none;
        }

        .archive-head {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 18px;
            padding: 18px 0;
        }

        .archive-label {
            font-size: 0.76rem;
            font-weight: 700;
        }

        .archive-head p {
            max-width: 32rem;
            margin: 0;
            line-height: 1.6;
        }

        .archive-list {
            display: flex;
            flex-direction: column;
        }

        .article {
            display: grid;
            grid-template-columns: 72px 220px minmax(0, 1fr) 84px;
            gap: 22px;
            padding: 22px 0;
            align-items: start;
        }

        .article-index {
            font-size: 0.72rem;
            font-weight: 700;
            padding-top: 6px;
        }

        .article-media {
            overflow: hidden;
            border: 1px solid var(--ink);
            background: #ecece8;
        }

        .article-media img {
            display: block;
            width: 100%;
            aspect-ratio: 4 / 3;
            object-fit: cover;
        }

        .article-body h2 {
            max-width: 18ch;
            margin: 0 0 12px;
            font-size: clamp(1.8rem, 3vw, 2.4rem);
            line-height: 1.02;
            letter-spacing: -0.05em;
        }

        .article-body p {
            max-width: 38rem;
            margin: 0;
            line-height: 1.68;
        }

        .article-meta {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 10px;
            padding-top: 6px;
        }

        .article-time {
            font-size: 0.72rem;
            font-weight: 700;
        }

        .article-link {
            color: var(--ink);
            text-decoration: none;
            font-weight: 700;
        }

        .article-link:hover,
        .article-link:focus-visible {
            text-decoration: underline;
            outline: none;
        }

        .note {
            padding-top: 20px;
            font-size: 0.95rem;
            line-height: 1.65;
        }

        .closing {
            padding-top: 28px;
            border-top: 2px solid var(--ink);
        }

        .contact-links {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .contact-link {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            min-height: 44px;
            padding: 0 16px;
            border: 1.5px solid var(--ink);
            color: var(--ink);
            text-decoration: none;
            font-size: 0.78rem;
            font-weight: 700;
            transition:
                transform 160ms ease,
                box-shadow 160ms ease,
                background-color 160ms ease,
                color 160ms ease;
        }

        .contact-link svg {
            flex: 0 0 18px;
            width: 18px;
            height: 18px;
        }

        .contact-link:hover {
            transform: translate(-3px, -3px);
            box-shadow: 6px 6px 0 var(--ink);
            background: var(--ink);
            color: var(--paper);
        }

        .contact-link:focus-visible {
            outline: none;
            transform: translate(-3px, -3px);
            box-shadow:
                0 0 0 3px var(--paper),
                0 0 0 5px var(--ink),
                6px 6px 0 var(--ink);
            background: var(--ink);
            color: var(--paper);
        }


        @media (max-width: 820px) {
            body {
                padding: 20px;
            }

            .page {
                padding: 22px;
            }

            .archive-head {
                grid-template-columns: 1fr;
            }

            .archive-head {
                align-items: flex-start;
            }

            .article {
                grid-template-columns: 1fr;
                gap: 16px;
            }

            .article-meta {
                flex-direction: row;
                align-items: center;
                justify-content: space-between;
                padding-top: 0;
            }
        }

        @media (max-width: 720px) {
            .topbar {
                flex-direction: column;
                align-items: flex-start;
            }

            h1 {
                max-width: none;
                font-size: clamp(2.5rem, 15vw, 4.3rem);
            }
        }
    </style>
</head>
<body>
    <main class="page">
        <header class="topbar">
            <div class="brand">
                <div class="brand-mark">RT</div>
                <div class="brand-copy">
                    <strong>Research and Tests</strong>
                    <span>Collected notes, experiments, and working articles</span>
                </div>
            </div>
            <div class="meta">Archive / Essays / Notes</div>
        </header>

        <section class="intro">
            <p class="eyebrow">Article Collection</p>
            <h1>All research articles in one column.</h1>
            <p class="lead">
                A quieter archive for essays, technical notes, experiments, and
                practical findings. Everything sits in one clear vertical flow,
                closer to an editorial list than a card grid.
            </p>

            <div class="tags">
                <a class="tag link active" href="/resnt">Research and Tests</a>
                <a class="tag link" href="/about">About me</a>
            </div>
        </section>

        <section class="archive-head">
            <div class="archive-label">Archive</div>
        </section>

        <section class="archive-list">
            {% if articles is defined and articles is not empty %}
                {% for article in articles %}
                    <article class="article">
                        <div class="article-index">{{ '%02d'|format(loop.index) }}</div>
                        <div class="article-media">
                            <img
                                src="{{ article.cover_image_url ?: '/assets/me.jpg' }}"
                                alt="{{ article.seo_title ?: article.title }}"
                            />
                        </div>
                        <div class="article-body">
                            <h2>{{ article.title }}</h2>
                            <p>{{ article.excerpt ?: article.seo_description ?: 'A published article without a short description yet.' }}</p>
                        </div>
                        <div class="article-meta">
                            <span class="article-time">
                                {% if article.published_at %}
                                    {{ article.published_at|date('d M Y') }}
                                {% else %}
                                    Published
                                {% endif %}
                            </span>
                            <a class="article-link" href="/post/{{ article.slug }}">Read</a>
                        </div>
                    </article>
                {% endfor %}
            {% else %}
                <article class="article">
                    <div class="article-index">00</div>
                    <div class="article-media">
                        <img src="/assets/me.jpg" alt="No articles yet" />
                    </div>
                    <div class="article-body">
                        <h2>No research posts yet.</h2>
                        <p>Once published articles appear in the database, they will be rendered here automatically.</p>
                    </div>
                    <div class="article-meta">
                        <span class="article-time">Waiting</span>
                        <a class="article-link" href="/integrations/cardform">Create</a>
                    </div>
                </article>
            {% endif %}
        </section>

       <section class="closing">
            <div class="contact-links" aria-label="Social links">
                <a class="contact-link" href="https://github.com/ananchevegor" target="_blank" rel="noreferrer">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 2.4a9.6 9.6 0 0 0-3 18.72c.48.09.66-.21.66-.48v-1.68c-2.7.6-3.27-1.14-3.27-1.14-.45-1.11-1.08-1.41-1.08-1.41-.9-.6.06-.57.06-.57 1.02.06 1.56 1.05 1.56 1.05.87 1.5 2.31 1.05 2.88.81.09-.66.36-1.05.63-1.29-2.16-.24-4.44-1.08-4.44-4.8 0-1.05.39-1.92 1.02-2.58-.09-.24-.45-1.23.12-2.55 0 0 .84-.27 2.73 1.02a9.45 9.45 0 0 1 4.98 0c1.89-1.29 2.73-1.02 2.73-1.02.57 1.32.21 2.31.12 2.55.66.66 1.02 1.53 1.02 2.58 0 3.72-2.28 4.56-4.47 4.8.36.3.66.87.66 1.77v2.61c0 .27.18.57.66.48A9.6 9.6 0 0 0 12 2.4Z" fill="currentColor"/>
                    </svg>
                    <span>GitHub</span>
                </a>

                <a class="contact-link" href="https://t.me/rea1eeea" target="_blank" rel="noreferrer">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M21.15 4.53 18.27 18.1c-.21.96-.78 1.2-1.59.75l-4.41-3.24-2.13 2.07c-.24.24-.42.42-.87.42l.3-4.53 8.28-7.5c.36-.33-.09-.51-.57-.18l-10.23 6.45-4.41-1.38c-.96-.3-.99-.96.21-1.41L19.38 3.2c.78-.3 1.47.18 1.77 1.32Z" fill="currentColor"/>
                    </svg>
                    <span>Telegram</span>
                </a>

                <a class="contact-link" href="mailto:egorka225522@gmail.com">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M3 6.75h18v10.5H3Z" fill="none" stroke="currentColor" stroke-width="1.8"/>
                        <path d="m4.5 8.25 7.5 6 7.5-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Email</span>
                </a>
            </div>
        </section>
    </main>
</body>
</html>
