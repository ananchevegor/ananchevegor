<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ananchev</title>
    <style>
        :root {
            --bg: #f5f5f2;
            --paper: #ffffff;
            --ink: #111111;
            --muted: #626262;
            --line: rgba(17, 17, 17, 0.14);
            font-family: "SF Pro Display", "SF Pro Text", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            margin: 0;
            min-height: 100%;
            color: var(--ink);
            background:
                linear-gradient(to right, rgba(17, 17, 17, 0.04) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(17, 17, 17, 0.04) 1px, transparent 1px),
                var(--bg);
            background-size: 32px 32px, 32px 32px, auto;
        }

        body {
            padding: 32px;
        }

        .page {
            width: min(900px, 100%);
            margin: 0 auto;
            padding: 28px;
            border: 1.5px solid var(--ink);
            background: var(--paper);
        }

        .topbar,
        .archive-head,
        .article {
            border-bottom: 1px solid var(--ink);
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            padding-bottom: 20px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .brand-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            border: 1.5px solid var(--ink);
            font-size: 0.86rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
        }

        .brand-copy {
            display: grid;
            gap: 4px;
        }

        .brand-copy strong,
        .meta,
        .eyebrow,
        .tag,
        .archive-label,
        .article-index,
        .article-time {
            text-transform: uppercase;
            letter-spacing: 0.16em;
        }

        .brand-copy strong {
            font-size: 0.88rem;
        }

        .brand-copy span,
        .meta,
        .lead,
        .archive-head p,
        .article p,
        .article-time,
        .note {
            color: var(--muted);
        }

        .meta {
            font-size: 0.8rem;
            white-space: nowrap;
        }

        .intro {
            padding: 36px 0 30px;
        }

        .eyebrow {
            margin: 0 0 18px;
            font-size: 0.76rem;
            font-weight: 700;
        }

        h1 {
            max-width: 11ch;
            margin: 0;
            font-size: clamp(3rem, 7vw, 5.8rem);
            line-height: 0.94;
            letter-spacing: -0.06em;
        }

        .lead {
            max-width: 40rem;
            margin: 24px 0 0;
            font-size: 1.04rem;
            line-height: 1.7;
        }

        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 26px;
        }

        .tag {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 40px;
            padding: 0 16px;
            border: 1px solid var(--ink);
            font-size: 0.74rem;
            font-weight: 700;
            text-decoration: none;
            color: var(--ink);
            transition: background-color 140ms ease, color 140ms ease;
        }

        .tag.link {
            gap: 10px;
        }

        .tag.link::after {
            font-size: 0.78rem;
            line-height: 1;
        }

        .tag:hover,
        .tag:focus-visible,
        .tag.active {
            background: var(--ink);
            color: var(--paper);
            outline: none;
        }

        .archive-head {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 18px;
            padding: 18px 0;
        }

        .archive-label {
            font-size: 0.76rem;
            font-weight: 700;
        }

        .archive-head p {
            max-width: 32rem;
            margin: 0;
            line-height: 1.6;
        }

        .archive-list {
            display: flex;
            flex-direction: column;
        }

        .article {
            display: grid;
            grid-template-columns: 72px 220px minmax(0, 1fr) 84px;
            gap: 22px;
            padding: 22px 0;
            align-items: start;
        }

        .article-index {
            font-size: 0.72rem;
            font-weight: 700;
            padding-top: 6px;
        }

        .article-media {
            overflow: hidden;
            border: 1px solid var(--ink);
            background: #ecece8;
        }

        .article-media img {
            display: block;
            width: 100%;
            aspect-ratio: 4 / 3;
            object-fit: cover;
        }

        .article-body h2 {
            max-width: 18ch;
            margin: 0 0 12px;
            font-size: clamp(1.8rem, 3vw, 2.4rem);
            line-height: 1.02;
            letter-spacing: -0.05em;
        }

        .article-body p {
            max-width: 38rem;
            margin: 0;
            line-height: 1.68;
        }

        .article-meta {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 10px;
            padding-top: 6px;
        }

        .article-time {
            font-size: 0.72rem;
            font-weight: 700;
        }

        .article-link {
            color: var(--ink);
            text-decoration: none;
            font-weight: 700;
        }

        .article-link:hover,
        .article-link:focus-visible {
            text-decoration: underline;
            outline: none;
        }

        .note {
            padding-top: 20px;
            font-size: 0.95rem;
            line-height: 1.65;
        }

        @media (max-width: 820px) {
            body {
                padding: 20px;
            }

            .page {
                padding: 22px;
            }

            .archive-head {
                grid-template-columns: 1fr;
            }

            .archive-head {
                align-items: flex-start;
            }

            .article {
                grid-template-columns: 1fr;
                gap: 16px;
            }

            .article-meta {
                flex-direction: row;
                align-items: center;
                justify-content: space-between;
                padding-top: 0;
            }
        }

        @media (max-width: 720px) {
            .topbar {
                flex-direction: column;
                align-items: flex-start;
            }

            h1 {
                max-width: none;
                font-size: clamp(2.5rem, 15vw, 4.3rem);
            }
        }
    </style>
</head>
<body>
    <main class="page">
        <header class="topbar">
            <div class="brand">
                <div class="brand-mark">RT</div>
                <div class="brand-copy">
                    <strong>Research and Tests</strong>
                    <span>Collected notes, experiments, and working articles</span>
                </div>
            </div>
            <div class="meta">Archive / Essays / Notes</div>
        </header>

        <section class="intro">
            <p class="eyebrow">Article Collection</p>
            <h1>All research articles in one column.</h1>
            <p class="lead">
                A quieter archive for essays, technical notes, experiments, and
                practical findings. Everything sits in one clear vertical flow,
                closer to an editorial list than a card grid.
            </p>

            <div class="tags">
                <a class="tag link active" href="/resnt">Research and Tests</a>
                <a class="tag link" href="/news">News</a>
                <a class="tag link" href="/about">About me</a>
            </div>
        </section>

        <section class="archive-head">
            <div class="archive-label">Archive</div>
            <p>
                A simple list of every article in the section. Later this can be
                rendered dynamically from real content.
            </p>
        </section>

        <section class="archive-list">
            {% if articles is defined and articles is not empty %}
                {% for article in articles %}
                    <article class="article">
                        <div class="article-index">{{ '%02d'|format(loop.index) }}</div>
                        <div class="article-media">
                            <img
                                src="{{ article.cover_image_url ?: '/assets/me.jpg' }}"
                                alt="{{ article.seo_title ?: article.title }}"
                            />
                        </div>
                        <div class="article-body">
                            <h2>{{ article.title }}</h2>
                            <p>{{ article.excerpt ?: article.seo_description ?: 'A published article without a short description yet.' }}</p>
                        </div>
                        <div class="article-meta">
                            <span class="article-time">
                                {% if article.published_at %}
                                    {{ article.published_at|date('d M Y') }}
                                {% else %}
                                    Published
                                {% endif %}
                            </span>
                            <a class="article-link" href="/post/{{ article.slug }}">Read</a>
                        </div>
                    </article>
                {% endfor %}
            {% else %}
                <article class="article">
                    <div class="article-index">00</div>
                    <div class="article-media">
                        <img src="/assets/me.jpg" alt="No articles yet" />
                    </div>
                    <div class="article-body">
                        <h2>No research posts yet.</h2>
                        <p>Once published articles appear in the database, they will be rendered here automatically.</p>
                    </div>
                    <div class="article-meta">
                        <span class="article-time">Waiting</span>
                        <a class="article-link" href="/integrations/cardform">Create</a>
                    </div>
                </article>
            {% endif %}
        </section>

        <p class="note">
            This layout is ready to become a real archive page once the article list
            starts coming from the database.
        </p>
    </main>
</body>
</html>
