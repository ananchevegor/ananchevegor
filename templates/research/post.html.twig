<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/assets/title_logo.png" />
    <title>{{ post.seo_title ?: post.title }}</title>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <style>
        :root {
            --bg: #f5f5f2;
            --paper: #ffffff;
            --ink: #111111;
            --muted: #626262;
            --line: rgba(17, 17, 17, 0.14);
            font-family: "SF Pro Display", "SF Pro Text", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            margin: 0;
            min-height: 100%;
            color: var(--ink);
            background:
                linear-gradient(to right, rgba(17, 17, 17, 0.04) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(17, 17, 17, 0.04) 1px, transparent 1px),
                var(--bg);
            background-size: 32px 32px, 32px 32px, auto;
        }

        body {
            padding: 32px;
        }

        .page {
            width: min(920px, 100%);
            margin: 0 auto;
            padding: 28px;
            border: 1.5px solid var(--ink);
            background: var(--paper);
        }

        .topbar,
        .article-header,
        .article-meta-row,
        .article-cover,
        .article-summary,
        .article-content,
        .bottom-bar {
            border-bottom: 1px solid var(--ink);
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            padding-bottom: 20px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .brand-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            border: 1.5px solid var(--ink);
            font-size: 0.86rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
        }

        .brand-copy {
            display: grid;
            gap: 4px;
        }

        .brand-copy strong,
        .meta,
        .eyebrow,
        .tag,
        .article-date,
        .back-link,
        .bottom-link {
            text-transform: uppercase;
            letter-spacing: 0.16em;
        }

        .brand-copy strong {
            font-size: 0.88rem;
        }

        .brand-copy span,
        .meta,
        .lead,
        .article-summary p,
        .article-content p,
        .article-content li,
        .bottom-note {
            color: var(--muted);
        }

        .meta {
            font-size: 0.8rem;
            white-space: nowrap;
        }

        .article-header {
            padding: 34px 0 24px;
        }

        .eyebrow {
            margin: 0 0 18px;
            font-size: 0.76rem;
            font-weight: 700;
        }

        .back-link,
        .bottom-link {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            color: var(--ink);
            text-decoration: none;
            font-size: 0.74rem;
            font-weight: 700;
        }

        .back-link::before,
        .bottom-link::before {
            font-size: 0.78rem;
            line-height: 1;
        } 

        h1 {
            max-width: 12ch;
            margin: 18px 0 0;
            font-size: clamp(3rem, 7vw, 5.8rem);
            line-height: 0.94;
            letter-spacing: -0.06em;
        }

        .lead {
            max-width: 42rem;
            margin: 22px 0 0;
            font-size: 1.08rem;
            line-height: 1.72;
        }

        .article-meta-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            padding: 16px 0;
        }

        .tag {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 40px;
            padding: 0 16px;
            border: 1px solid var(--ink);
            font-size: 0.74rem;
            font-weight: 700;
            text-decoration: none;
            color: var(--ink);
        }

        .tag.active {
            background: var(--ink);
            color: var(--paper);
        }

        .article-date {
            font-size: 0.74rem;
            font-weight: 700;
        }

        .article-cover {
            padding: 22px 0;
        }

        .article-cover img {
            display: block;
            width: 100%;
            max-height: 560px;
            object-fit: cover;
            border: 1px solid var(--ink);
        }

        .article-summary {
            padding: 24px 0;
        }

        .article-summary p {
            max-width: 44rem;
            margin: 0;
            font-size: 1.02rem;
            line-height: 1.72;
        }

        .article-content {
            padding: 26px 0 24px;
        }

        .article-content .content {
            max-width: 44rem;
            font-size: 1.02rem;
            line-height: 1.9;
        }

        .article-content p {
            margin: 0 0 18px;
        }

        .article-content h2,
        .article-content h3,
        .article-content h4 {
            color: var(--ink);
            letter-spacing: -0.03em;
            line-height: 1.1;
        }

        .article-content h2 {
            margin: 40px 0 16px;
            font-size: clamp(1.8rem, 3vw, 2.4rem);
        }

        .article-content h3 {
            margin: 32px 0 14px;
            font-size: clamp(1.4rem, 2.4vw, 1.8rem);
        }

        .article-content h4 {
            margin: 26px 0 12px;
            font-size: 1.15rem;
        }

        .article-content blockquote {
            margin: 24px 0;
            padding-left: 18px;
            border-left: 2px solid var(--ink);
            color: var(--ink);
        }

        .article-content ul,
        .article-content ol {
            margin: 0 0 20px;
            padding-left: 24px;
        }

        .article-content li {
            margin-bottom: 10px;
        }

        .article-content a {
            color: var(--ink);
            text-decoration-thickness: 1px;
            text-underline-offset: 3px;
        }

        .article-content code {
            padding: 2px 6px;
            background: rgba(17, 17, 17, 0.06);
            border: 1px solid rgba(17, 17, 17, 0.12);
            font-family: "SF Mono", "JetBrains Mono", "Cascadia Code", "Consolas", monospace;
            font-size: 0.92em;
        }

        .article-content pre {
            margin: 24px 0;
            padding: 18px;
            overflow-x: auto;
            border: 1px solid var(--ink);
            background: #f0f0ec;
        }

        .article-content pre code {
            padding: 0;
            border: none;
            background: transparent;
        }

        .article-content hr {
            margin: 28px 0;
            border: none;
            border-top: 1px solid var(--ink);
        }

        .article-content table {
            width: 100%;
            margin: 24px 0;
            border-collapse: collapse;
        }

        .article-content th,
        .article-content td {
            padding: 12px 14px;
            border: 1px solid var(--ink);
            text-align: left;
            vertical-align: top;
        }

        .article-content thead th {
            background: rgba(17, 17, 17, 0.06);
            color: var(--ink);
        }

        .markdown-source {
            display: none;
        }

        .bottom-bar {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 18px;
            padding: 22px 0 0;
            border-bottom: none;
        }

        .bottom-note {
            max-width: 30rem;
            margin: 0;
            line-height: 1.65;
        }

        @media (max-width: 820px) {
            body {
                padding: 20px;
            }

            .page {
                padding: 22px;
            }

            .article-meta-row,
            .bottom-bar {
                flex-direction: column;
                align-items: flex-start;
            }
        }

        @media (max-width: 720px) {
            .topbar {
                flex-direction: column;
                align-items: flex-start;
            }

            h1 {
                max-width: none;
                font-size: clamp(2.5rem, 15vw, 4.4rem);
            }
        }
    </style>
</head>
<body>
    <main class="page">
        <header class="topbar">
            <div class="brand">
                <div class="brand-mark">RT</div>
                <div class="brand-copy">
                    <strong>Research and Tests</strong>
                    <span>Single article view</span>
                </div>
            </div>
            <div class="meta">Post / Read / Archive</div>
        </header>

        <section class="article-header">
            <a class="back-link" href="/resnt">Back to archive</a>
            <p class="eyebrow">Article</p>
            <h1>{{ post.title }}</h1>
            {% if post.seo_description or post.excerpt %}
                <p class="lead">{{ post.seo_description ?: post.excerpt }}</p>
            {% endif %}
        </section>

        <section class="article-meta-row">
            <span class="tag active">Research and Tests</span>
            <span class="article-date">
                {% if post.published_at %}
                    {{ post.published_at|date('d M Y') }}
                {% else %}
                    Published
                {% endif %}
            </span>
        </section>

        <section class="article-cover">
            <img
                src="{{ post.cover_image_url ?: '/assets/me.jpg' }}"
                alt="{{ post.seo_title ?: post.title }}"
            />
        </section>

        {% if post.excerpt %}
            <section class="article-summary">
                <p>{{ post.excerpt }}</p>
            </section>
        {% endif %}

        <section class="article-content">
            <div class="content">
                {% if post.content %}
                    <textarea class="markdown-source" id="post-markdown-source">{{ post.content }}</textarea>
                    <div id="post-markdown-rendered"></div>
                    <noscript>{{ post.content|nl2br }}</noscript>
                {% else %}
                    <p>This post does not have article body content yet.</p>
                {% endif %}
            </div>
        </section>

        <section class="bottom-bar">
            <a class="bottom-link" href="/resnt">Back to archive</a>
        </section>
    </main>
    <script>
        const markdownSource = document.getElementById('post-markdown-source');
        const markdownRendered = document.getElementById('post-markdown-rendered');

        if (markdownSource && markdownRendered) {
            const markdownText = markdownSource.value || '';

            if (window.marked) {
                marked.setOptions({
                    breaks: true,
                    gfm: true
                });

                markdownRendered.innerHTML = marked.parse(markdownText);
            } else {
                markdownRendered.innerHTML = markdownText
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/\n/g, '<br>');
            }
        }
    </script>
</body>
</html>
