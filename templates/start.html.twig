<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ananchev</title>
    <style>
        :root {
            --bg: #f3f3f1;
            --paper: #ffffff;
            --ink: #111111;
            --line: rgba(17, 17, 17, 0.16);
            --soft-line: rgba(17, 17, 17, 0.08);
            --muted: #5d5d5d;
            --shadow: 16px 16px 0 #111111;
            font-family: "SF Pro Display", "SF Pro Text", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            margin: 0;
            min-height: 100%;
            color: var(--ink);
            background-color: var(--bg);
            background-image:
                linear-gradient(to right, var(--soft-line) 1px, transparent 1px),
                linear-gradient(to bottom, var(--soft-line) 1px, transparent 1px);
            background-size: 32px 32px;
        }

        body {
            min-height: 100vh;
            padding: 32px;
        }

        .page {
            width: min(1180px, 100%);
            margin: 0 auto;
            padding: 28px;
            border: 2px solid var(--ink);
            background: var(--paper);
            box-shadow: var(--shadow);
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 24px;
            padding-bottom: 20px;
            border-bottom: 2px solid var(--ink);
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .brand-mark {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 48px;
            height: 48px;
            border: 2px solid var(--ink);
            font-size: 0.9rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
        }

        .brand-copy {
            display: grid;
            gap: 4px;
        }

        .brand-copy strong,
        .meta,
        .eyebrow,
        .tag,
        .card-label {
            text-transform: uppercase;
            letter-spacing: 0.16em;
        }

        .brand-copy strong {
            font-size: 0.9rem;
        }

        .brand-copy span,
        .meta,
        .lead,
        .card p,
        .status {
            color: var(--muted);
        }

        .meta {
            font-size: 0.82rem;
            white-space: nowrap;
        }

        .hero {
            display: grid;
            grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
            gap: 40px;
            padding: 36px 0;
            align-items: center;
        }

        .eyebrow {
            margin: 0 0 20px;
            font-size: 0.78rem;
            font-weight: 700;
        }

        h1 {
            margin: 0;
            max-width: 11ch;
            font-size: clamp(3.2rem, 7vw, 6.5rem);
            line-height: 0.94;
            letter-spacing: -0.06em;
        }

        .lead {
            max-width: 34rem;
            margin: 28px 0 0;
            font-size: 1.08rem;
            line-height: 1.7;
        }

        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 28px;
        }

        .tag {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 44px;
            padding: 0 18px;
            border: 1.5px solid var(--ink);
            font-size: 0.76rem;
            font-weight: 700;
            text-decoration: none;
            color: var(--ink);
            transition:
                transform 160ms ease,
                box-shadow 160ms ease,
                background-color 160ms ease,
                color 160ms ease;
        }

        .tag.inverse {
            background: var(--ink);
            color: var(--paper);
        }

        .tag.link {
            gap: 12px;
            position: relative;
        }

        .tag.link::after {
            font-size: 0.8rem;
            line-height: 1;
        }

        .tag:hover {
            transform: translate(-3px, -3px);
            box-shadow: 6px 6px 0 var(--ink);
        }

        .tag.inverse:hover {
            background: #2a2a2a;
        }

        .tag:focus-visible {
            outline: none;
            transform: translate(-3px, -3px);
            box-shadow:
                0 0 0 3px var(--paper),
                0 0 0 5px var(--ink),
                6px 6px 0 var(--ink);
        }

        .visual {
            position: relative;
            display: grid;
            grid-template-columns: 0.94fr 0.94fr 0.94fr 1.06fr 1.06fr 1.06fr;
            grid-template-rows: repeat(9, minmax(84px, auto));
            gap: 12px;
            min-height: 100%;
        }

        .card {
            position: relative;
            display: flex;
            flex-direction: column;
            gap: 10px;
            padding: 18px;
            border: 2px solid var(--ink);
            background: var(--paper);
            overflow: hidden
        }

        .card.photo {
            gap: 14px;
            padding: 14px;
            background: var(--paper);
        }

        .card.dark {
            background: var(--ink);
            color: var(--paper);
        }

        .card.dark p {
            color: rgba(255, 255, 255, 0.72);
        }

        .card::before {
            content: "";
            position: absolute;
            inset: 10px;
            border: 1px solid var(--soft-line);
            pointer-events: none;
        }

        .card.a {
            grid-column: 1 / 4;
            grid-row: 1 / 4;
            justify-content: flex-end;
        }

        .card.b {
            grid-column: 4 / 7;
            grid-row: 1 / 5;
        }

        .card.c {
            grid-column: 1 / 4;
            grid-row: 4 / 10;
            justify-content: flex-start;
            background: var(--paper);
        }

        .card.d {
            grid-column: 4 / 7;
            grid-row: 6 / 10;
            justify-content: flex-start;
            background: var(--paper);
        }

        .card.e {
            grid-column: 1 / 4;
            grid-row: 3 / 4;
        }

        .card-label {
            display: inline-block;
            width: fit-content;
            margin-bottom: 6px;
            padding: 6px 10px;
            border: 1.5px solid currentColor;
            background: var(--paper);
            font-size: 0.74rem;
            font-weight: 700;
        }

        .card.dark .card-label {
            background: var(--ink);
            border-color: rgba(255, 255, 255, 0.24);
        }

        .card strong {
            display: block;
            max-width: 12ch;
            font-size: 1.55rem;
            line-height: 1.1;
        }

        .card p {
            margin: 14px 0 0;
            max-width: 20ch;
            line-height: 1.5;
        }

        .card-note {
            margin: 0;
            max-width: 26ch;
            line-height: 1.55;
        }

        .card.a strong,
        .card.c strong,
        .card.d strong {
            max-width: none;
        }

        .card.a strong {
            max-width: 11ch;
            font-size: clamp(1.9rem, 2.4vw, 2.5rem);
        }

        .card.a .card-note {
            color: rgba(255, 255, 255, 0.72);
        }

        .card.c p {
            margin: 0;
            max-width: none;
            font-size: 0.9rem;
            line-height: 1.4;
        }

        .card.d strong {
            max-width: 12ch;
        }

        .photo-frame {
            position: relative;
            display: flex;
            flex: 1;
            min-height: 100%;
            flex-direction: column;
            justify-content: space-between;
            padding: 18px;
            border: 2px solid var(--ink);
            background:
                linear-gradient(to right, var(--soft-line) 1px, transparent 1px),
                linear-gradient(to bottom, var(--soft-line) 1px, transparent 1px),
                var(--paper);
            background-size: 24px 24px, 24px 24px, auto;
            overflow: hidden;
        }

        .photo-frame::after {
            content: "";
            position: absolute;
            inset: 14px;
            border: 1px solid rgba(17, 17, 17, 0.18);
            pointer-events: none;
        }

        .photo-frame img {
            display: block;
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center top;
            filter: saturate(0.98) contrast(1.03);
            transform: scale(1.02);
        }

        .stack-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 8px;
            margin: 12px 0 0;
            padding: 0;
            list-style: none;
        }

        .stack-pill {
            display: flex;
            align-items: center;
            gap: 8px;
            min-height: 44px;
            min-width: 0;
            padding: 8px 10px;
            border: 1.5px solid var(--ink);
            background: var(--paper);
            font-size: 0.88rem;
            font-weight: 700;
            line-height: 1.1;
        }

        .stack-pill svg,
        .stack-pill img {
            flex: 0 0 20px;
            width: 20px;
            height: 20px;
            display: block;
            object-fit: contain;
        }

        .stack-pill span {
            min-width: 0;
        }

        .photo-meta {
            position: relative;
            z-index: 1;
            display: flex;
            justify-content: space-between;
            gap: 12px;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
        }

        .photo-mark {
            position: relative;
            z-index: 1;
            margin: 0;
            font-size: clamp(2.4rem, 5vw, 4.8rem);
            line-height: 0.9;
            letter-spacing: -0.07em;
            text-transform: uppercase;
        }

        .photo-note {
            position: relative;
            z-index: 1;
            max-width: 16ch;
            margin: 0;
            color: var(--muted);
            line-height: 1.45;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
            padding-top: 28px;
            border-top: 2px solid var(--ink);
        }

        .latest-posts {
            padding-top: 28px;
            border-top: 2px solid var(--ink);
            padding-bottom: 28px;
        }

        .latest-head {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 18px;
            margin-bottom: 22px;
        }

        .latest-head p,
        .post-excerpt,
        .post-date {
            color: var(--muted);
        }

        .latest-head h2,
        .post-title {
            letter-spacing: -0.04em;
        }

        .latest-head h2 {
            margin: 0;
            font-size: clamp(2rem, 4vw, 3rem);
            line-height: 0.96;
        }

        .latest-head p {
            max-width: 32rem;
            margin: 0;
            line-height: 1.65;
        }

        .posts-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
        }

        .post-card {
            display: grid;
            gap: 16px;
            padding: 18px;
            border: 1.5px solid var(--ink);
            background:
                linear-gradient(135deg, rgba(17, 17, 17, 0.04), transparent 58%),
                var(--paper);
        }

        .post-cover {
            overflow: hidden;
            border: 1.5px solid var(--ink);
            background: #ecece8;
        }

        .post-cover img {
            display: block;
            width: 100%;
            aspect-ratio: 4 / 3;
            object-fit: cover;
        }

        .post-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .post-date,
        .post-link {
            font-size: 0.74rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.14em;
        }

        .post-title {
            margin: 0;
            font-size: 1.6rem;
            line-height: 1.06;
        }

        .post-excerpt {
            margin: 0;
            line-height: 1.65;
        }

        .post-link {
            color: var(--ink);
            text-decoration: none;
        }

        .post-link:hover,
        .post-link:focus-visible {
            text-decoration: underline;
            outline: none;
        }

        .empty-posts {
            padding: 24px;
            border: 1.5px solid var(--ink);
            color: var(--muted);
            line-height: 1.65;
        }

        .info-box {
            min-height: 150px;
            padding: 20px;
            border: 1.5px solid var(--ink);
            background:
                linear-gradient(135deg, rgba(17, 17, 17, 0.04), transparent 55%),
                var(--paper);
        }

        .info-box h2 {
            margin: 0 0 14px;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.14em;
        }

        .info-box p {
            margin: 0;
            color: var(--muted);
            line-height: 1.6;
        }

        .status {
            margin-top: 16px;
            font-size: 0.95rem;
        }

        .closing {
            padding-top: 28px;
            border-top: 2px solid var(--ink);
        }

        .contact-links {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .contact-link {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            min-height: 44px;
            padding: 0 16px;
            border: 1.5px solid var(--ink);
            color: var(--ink);
            text-decoration: none;
            font-size: 0.78rem;
            font-weight: 700;
            transition:
                transform 160ms ease,
                box-shadow 160ms ease,
                background-color 160ms ease,
                color 160ms ease;
        }

        .contact-link svg {
            flex: 0 0 18px;
            width: 18px;
            height: 18px;
        }

        .contact-link:hover {
            transform: translate(-3px, -3px);
            box-shadow: 6px 6px 0 var(--ink);
            background: var(--ink);
            color: var(--paper);
        }

        .contact-link:focus-visible {
            outline: none;
            transform: translate(-3px, -3px);
            box-shadow:
                0 0 0 3px var(--paper),
                0 0 0 5px var(--ink),
                6px 6px 0 var(--ink);
            background: var(--ink);
            color: var(--paper);
        }

        @media (max-width: 980px) {
            body {
                padding: 20px;
            }

            .page {
                padding: 22px;
                box-shadow: 10px 10px 0 #111111;
            }

            .hero,
            .footer-grid,
            .posts-grid {
                grid-template-columns: 1fr;
            }

            .latest-head {
                flex-direction: column;
                align-items: flex-start;
            }

            .visual {
                grid-template-rows: repeat(9, minmax(72px, auto));
            }

            .stack-pill {
                min-height: 42px;
                padding: 9px 10px;
            }
        }

        @media (max-width: 720px) {
            .topbar {
                flex-direction: column;
                align-items: flex-start;
            }

            h1 {
                max-width: none;
                font-size: clamp(2.6rem, 16vw, 4.5rem);
            }

            .visual {
                grid-template-columns: repeat(2, 1fr);
                grid-template-rows: auto;
            }

            .card.a,
            .card.b,
            .card.c,
            .card.d,
            .card.e {
                grid-column: auto;
                grid-row: auto;
                min-height: 180px;
            }
        }
    </style>
</head>
<body>
    <main class="page">
        <header class="topbar">
            <div class="brand">
                <div class="brand-mark">SF</div>
                <div class="brand-copy">
                    <strong>The Blog</strong>
                    <span>A space for solutions, clear and fast code</span>
                </div>
            </div>
            <div class="meta">Black / White / Geometry</div>
        </header>

        <section class="hero">
            <div class="copy">
                <p class="eyebrow">Welcome!</p>
                <h1>Hello. I am Egor Ananchev, and this is where things work faster.</h1>
                <p class="lead">
                    The goal of this blog is to explore how we can make code faster, cleaner, and more efficient.
                    Here I write about what I think, what I build, and what I imagine.
                </p>

                <div class="tags">
                    <a class="tag link" href="/resnt">Research and Tests</a>
                    <a class="tag link" href="/about">About me</a>
                </div>
            </div>

            <div class="visual">
                <article class="card a dark">
                    <span class="card-label">01</span>
                    <strong>Fast sites. Clean code. No extra weight.</strong>
                    <p class="card-note">This blog is about performance, clarity, and systems that stay quick as they grow.</p>
                </article>

                <article class="card b photo">
                    <span class="card-label">02</span>
                    <div class="photo-frame">
                       <img src="/assets/me.jpg" alt="Portrait photo" />
                    </div>
                </article>

                <article class="card c">
                    <span class="card-label">03</span>
                    <strong>Tech Stack</strong>
                    <p>Core tools I use to build fast websites, efficient backends, and clean product code.</p>
                    <ul class="stack-grid">
                        <li class="stack-pill php">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <ellipse cx="12" cy="12" rx="10.5" ry="7.2" fill="none" stroke="#111111" stroke-width="1.5"/>
                                <text x="12" y="14.6" fill="#111111" font-size="6.2" font-weight="700" text-anchor="middle">PHP</text>
                            </svg>
                            <span>PHP</span>
                        </li>
                        <li class="stack-pill js">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <rect x="2.75" y="2.75" width="18.5" height="18.5" fill="none" stroke="#111111" stroke-width="1.5"/>
                                <text x="12" y="15.4" fill="#111111" font-size="8.2" font-weight="700" text-anchor="middle">JS</text>
                            </svg>
                            <span>JavaScript</span>
                        </li>
                        <li class="stack-pill python">
                            <img src="/assets/python-logo-only.svg" alt="" aria-hidden="true" />
                            <span>Python</span>
                        </li>
                        <li class="stack-pill sql">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <ellipse cx="12" cy="5.4" rx="7.2" ry="3.1" fill="none" stroke="#111111" stroke-width="1.4"/>
                                <path d="M4.8 5.4v4c0 1.7 3.2 3.1 7.2 3.1s7.2-1.4 7.2-3.1v-4" fill="none" stroke="#111111" stroke-width="1.4"/>
                                <path d="M4.8 10.2v4c0 1.7 3.2 3.1 7.2 3.1s7.2-1.4 7.2-3.1v-4" fill="none" stroke="#111111" stroke-width="1.4"/>
                                <path d="M4.8 15v3.6c0 1.7 3.2 3.1 7.2 3.1s7.2-1.4 7.2-3.1V15" fill="none" stroke="#111111" stroke-width="1.4"/>
                            </svg>
                            <span>SQL</span>
                        </li>
                        <li class="stack-pill rn">
                            <img src="/assets/react-native-logo.png" alt="" aria-hidden="true" />
                            <span>React Native</span>
                        </li>
                        <li class="stack-pill kotlin">
                            <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            aria-hidden="true"
                            role="img"
                            >
                            <path fill="#7F52FF" d="M3 3h18L3 21V3z"/>
                            <path fill="#FF8A00" d="M3 21l9-9 9 9H3z"/>
                            <path fill="#E44857" d="M21 3L12 12l9 9V3z"/>
                            </svg>
                            <span>Kotlin</span>
                        </li>
                        <li class="stack-pill cpp">
                            <img src="/assets/ISO_C++_Logo.svg.png" alt="" aria-hidden="true" />
                            <span>C++</span>
                        </li>
                    </ul>
                </article>

                <article class="card d">
                    <span class="card-label">04</span>
                    <strong>What does clean code mean?</strong>
                    <p class="card-note">Readable names, direct logic, and only the abstractions that actually help.</p>
                </article>

            </div>
        </section>

        <section class="latest-posts">

            {% if posts is defined and posts is not empty %}
                <div class="posts-grid">
                    {% for post in posts %}
                        <article class="post-card">
                            <div class="post-cover">
                                <img
                                    src="{{ post.cover_image_url ?: '/assets/me.jpg' }}"
                                    alt="{{ post.seo_title ?: post.title }}"
                                />
                            </div>

                            <div class="post-meta">
                                <span class="post-date">
                                    {% if post.published_at %}
                                        {{ post.published_at|date('d M Y') }}
                                    {% else %}
                                        Published
                                    {% endif %}
                                </span>
                                <a class="post-link" href="/post/{{ post.slug }}">Read</a>
                            </div>

                            <h3 class="post-title">{{ post.title }}</h3>
                            <p class="post-excerpt">{{ post.excerpt ?: post.seo_description ?: 'A published post without a short summary yet.' }}</p>
                        </article>
                    {% endfor %}
                </div>
            {% else %}
                <div class="empty-posts">
                    Published posts will appear here once the first articles are available in the archive.
                </div>
            {% endif %}
        </section>
        <section class="closing">
            <div class="contact-links" aria-label="Social links">
                <a class="contact-link" href="https://github.com/ananchevegor" target="_blank" rel="noreferrer">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 2.4a9.6 9.6 0 0 0-3 18.72c.48.09.66-.21.66-.48v-1.68c-2.7.6-3.27-1.14-3.27-1.14-.45-1.11-1.08-1.41-1.08-1.41-.9-.6.06-.57.06-.57 1.02.06 1.56 1.05 1.56 1.05.87 1.5 2.31 1.05 2.88.81.09-.66.36-1.05.63-1.29-2.16-.24-4.44-1.08-4.44-4.8 0-1.05.39-1.92 1.02-2.58-.09-.24-.45-1.23.12-2.55 0 0 .84-.27 2.73 1.02a9.45 9.45 0 0 1 4.98 0c1.89-1.29 2.73-1.02 2.73-1.02.57 1.32.21 2.31.12 2.55.66.66 1.02 1.53 1.02 2.58 0 3.72-2.28 4.56-4.47 4.8.36.3.66.87.66 1.77v2.61c0 .27.18.57.66.48A9.6 9.6 0 0 0 12 2.4Z" fill="currentColor"/>
                    </svg>
                    <span>GitHub</span>
                </a>

                <a class="contact-link" href="https://t.me/rea1eeea" target="_blank" rel="noreferrer">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M21.15 4.53 18.27 18.1c-.21.96-.78 1.2-1.59.75l-4.41-3.24-2.13 2.07c-.24.24-.42.42-.87.42l.3-4.53 8.28-7.5c.36-.33-.09-.51-.57-.18l-10.23 6.45-4.41-1.38c-.96-.3-.99-.96.21-1.41L19.38 3.2c.78-.3 1.47.18 1.77 1.32Z" fill="currentColor"/>
                    </svg>
                    <span>Telegram</span>
                </a>

                <a class="contact-link" href="mailto:egorka225522@gmail.com">
